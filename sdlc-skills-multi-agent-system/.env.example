# Vertex AI Configuration
# Authenticate against Gemini through Vertex AI (default).
GOOGLE_GENAI_USE_VERTEXAI=true
# GCP project id (required)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# Region for Vertex AI (defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1
# Path to the service-account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# Optional API-key fallback (only used when GOOGLE_GENAI_USE_VERTEXAI=false)
# GEMINI_API_KEY=your_gemini_api_key_here

# SQLite Database Location
DATABASE_URL=sqlite:///skillforge.db
